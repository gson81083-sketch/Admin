    CreateToggle("Tàng hình", 250, function(Enabled)
        RefreshChar()
        if not Char then return end
        if Enabled then
            Original.Transparency = {}
            for _,p in ipairs(Char:GetDescendants()) do
                if p:IsA("BasePart") or p:IsA("Decal") or p:IsA("Texture") then
                    Original.Transparency[p] = p.Transparency or 0
                    p.Transparency = 1
                elseif p:IsA("Shirt") or p:IsA("Pants") or p:IsA("Accessory") then
                    p.Transparency = 1
                end
            end
            StarterGui:SetCore("NameDisplayDistance", 0)
            StarterGui:SetCore("HealthDisplayDistance", 0)
        else
            for p,trans in pairs(Original.Transparency) do if p and p:IsDescendantOf(Char) then p.Transparency = trans end end
            for _,p in ipairs(Char:GetDescendants()) do if p:IsA("Shirt") or p:IsA("Pants") or p:IsA("Accessory") then p.Transparency = 0 end end
            StarterGui:SetCore("NameDisplayDistance", 100)
            StarterGui:SetCore("HealthDisplayDistance", 100)
        end
    end)
