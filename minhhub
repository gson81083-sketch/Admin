            RefreshChar() if not HRP or Hum.Health <= 0 then return end
            local ray = RaycastParams.new() ray.FilterDescendantsInstances = {Char} ray.FilterType = Enum.RaycastFilterType.Blacklist
            local res = Workspace:Raycast(HRP.Position, Vector3.new(0, -5, 0), ray)
            if res and res.Instance.Name:lower():find("water") then HRP.Velocity = Vector3.new(0, 8, 0) end
        end) end
    end)
    CreateToggle("Không bị đẩy lùi", 750, function(Enabled)
        RefreshChar() if not HRP then return end
        local ab = HRP:FindFirstChild("AntiKB") or Instance.new("BodyVelocity", HRP)
        ab.Name = "AntiKB"
        ab.MaxForce = Enabled and Vector3.new(1e6, 0, 1e6) or Vector3.new(0,0,0)
    end)
    CreateToggle("Aim Bot", 800, function(Enabled)
        AimSettings.Enabled = Enabled
        if Conn.Aim then Conn.Aim:Disconnect() Conn.Aim = nil end
        if not Enabled then return end
        local function GetClosestEnemy()
            local closest, dist = nil, AimSettings.Range
            for _,v in ipairs(Players:GetPlayers()) do
                if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.Humanoid.Health > 0 then
                    local part = v.Character:FindFirstChild(AimSettings.Part) or v.Character.Head
                    local d = (Camera.CFrame.Position - part.Position).Magnitude
                    if d < dist then dist = d; closest = part end
                end
            end
            return closest
        end
        Conn.Aim = RunService.RenderStepped:Connect(function()
            if not AimSettings.Enabled then return end
            local target = GetClosestEnemy()
            if target then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), AimSettings.Smooth) end
        end)
    end)

