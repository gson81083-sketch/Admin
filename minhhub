        if Enabled then
            Conn.TeleTouch = UserInputService.InputBegan:Connect(function(input)
                if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and not HubVisible then
                    RefreshChar() if not HRP or Hum.Health <= 0 then return end
                    local ray = Camera:ScreenPointToRay(input.Position.X, input.Position.Y)
                    local rayParam = RaycastParams.new()
                    rayParam.FilterDescendantsInstances = {Char}
                    rayParam.FilterType = Enum.RaycastFilterType.Blacklist
                    local result = Workspace:Raycast(ray.Origin, ray.Direction * 1200, rayParam)
                    if result then HRP.CFrame = CFrame.new(result.Position + Vector3.new(0, 2.5, 0)) HRP.Velocity = Vector3.new(0,0,0) end
                end
            end)
        end
    end)
    CreateToggle("Nhảy tường (Wallhop)", 350, function(Enabled)
        if Conn.Wallhop then Conn.Wallhop:Disconnect() Conn.Wallhop = nil end
        if Enabled then
            local lastJump = 0
            Conn.Wallhop = RunService.Heartbeat:Connect(function()
                RefreshChar() if not Hum or Hum.Health <= 0 or not HRP then return end
                local state = Hum:GetState()
                if state == Enum.HumanoidStateType.Freefall or state == Enum.HumanoidStateType.Jumping then
                    local rayParam = RaycastParams.new()
                    rayParam.FilterDescendantsInstances = {Char}
                    rayParam.FilterType = Enum.RaycastFilterType.Blacklist
                    local dirs = {Vector3.new(1,0,0), Vector3.new(-1,0,0), Vector3.new(0,0,1), Vector3.new(0,0,-1)}
                    for _,d in ipairs(dirs) do
                        local res = Workspace:Raycast(HRP.Position, d * 2.3, rayParam)
                        if res and os.clock() - lastJump > 0.3 then
                            Hum:ChangeState(Enum.HumanoidStateType.Jumping)
                            HRP.Velocity = Vector3.new(-d.X * 60, 52, -d.Z * 60)
                            lastJump = os.clock()
                            break
                        end
                    end
                end
            end)
        end
    end)
    CreateToggle("Xuyên tường", 400, function(Enabled)
        if Conn.NoClip then Conn.NoClip:Disconnect() Conn.NoClip = nil end
