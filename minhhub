-- Kiểm tra mã đúng/sai
local function CheckKey()
    local input = KeyInput.Text:lower():gsub("%s+", "")
    if input == HubKey then
        StatusText.TextColor3 = Color3.fromRGB(60, 220, 100)
        StatusText.Text = "✅ Mã đúng! Đang mở hub..."
        task.wait(0.8)
        KeyGui:Destroy()
        HubUnlocked = true
        LoadMainHub()
    else
        StatusText.Text = "❌ Mã sai! Thử lại"
    end
end

SubmitBtn.MouseButton1Click:Connect(CheckKey)
KeyInput.FocusLost:Connect(function(enterPressed) if enterPressed then CheckKey() end end)

