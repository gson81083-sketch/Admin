    -- Hàm tạo công cụ dịch chuyển
    local function CreateTPTool()
        local Tool = Instance.new("Tool")
        Tool.Name = "TeleportTool"
        Tool.RequiresHandle = false
        Tool.CanBeDropped = false
        Tool.Parent = Player.Backpack

        local equipped = false
        Tool.Equipped:Connect(function() equipped = true end)
        Tool.Unequipped:Connect(function() equipped = false end)

        Mouse.Button1Down:Connect(function()
            if equipped and Tool:IsDescendantOf(Char) then
                local hit = Mouse.Hit
                if HRP then
                    HRP.CFrame = CFrame.new(hit.Position + Vector3.new(0, 3, 0))
                    HRP.Velocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end

    -- Gọi khi nhấn nút nhận công cụ
    GetTPBtn.MouseButton1Click:Connect(function()
        CreateTPTool()
        GetTPBtn.BackgroundColor3 = Color3.fromRGB(40, 150, 60)
        GetTPBtn.Text = "✅ Đã nhận công cụ"
        task.wait(2)
        GetTPBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 80)
