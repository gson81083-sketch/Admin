    -- Chức năng kéo thả khung
    local Drag = {Enabled = false, Start = nil, Offset = nil}
    TitleBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            Drag.Enabled = true
            Drag.Start = i.Position
            Drag.Offset = MainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if Drag.Enabled then
            local delta = i.Position - Drag.Start
            MainFrame.Position = UDim2.new(Drag.Offset.X.Scale, Drag.Offset.X.Offset + delta.X, Drag.Offset.Y.Scale, Drag.Offset.Y.Offset + delta.Y)
